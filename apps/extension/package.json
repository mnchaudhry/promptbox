{
  "name": "extension",
  "displayName": "Promptly",
  "version": "0.0.1",
  "description": "Industrial Authority Prompt Saver",
  "author": "Promptly Team",
  "packageManager": "npm@10.9.2",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build --no-cache",
    "package": "plasmo package",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "deploy": "echo 'Deploying extension bits...'"
  },
  "dependencies": {
    "@promptly/ui": "workspace:*",
    "@promptly/shared": "workspace:*",
    "plasmo": "0.90.5",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "0.0.268",
    "@types/node": "20.12.7",
    "@types/react": "18.3.1",
    "@types/react-dom": "18.3.1",
    "autoprefixer": "10.4.19",
    "postcss": "8.4.38",
    "tailwindcss": "3.4.3",
    "typescript": "5.4.5",
    "eslint": "^9"
  },
  "manifest": {
    "host_permissions": [
      "https://*/*"
    ],
    "permissions": [
      "clipboardRead",
      "clipboardWrite",
      "storage"
    ]
  }
}
